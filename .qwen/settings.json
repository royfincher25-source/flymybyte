{
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git rm *)",
      "Bash(pytest *)",
      "Bash(findstr *)"
    ]
  },
  "$version": 3,
  "general": {
    "terminalBell": false
  },
  "ui": {
    "enableUserFeedback": false,
    "accessibility": {
      "enableLoadingPhrases": false
    }
  }
}