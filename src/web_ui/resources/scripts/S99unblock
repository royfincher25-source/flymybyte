#!/bin/sh
# S99unblock - Скрипт автоматического заполнения множества unblock при загрузке

mkdir -p /opt/var/log
LOGFILE="/opt/var/log/S99unblock.log"
TAG="S99unblock"

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') [$TAG] $1" >> "$LOGFILE"
}

log_error() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') [$TAG] ERROR: $1" >> "$LOGFILE"
}

log "=== S99unblock called with action: $1 ==="

# Логируем системную информацию для отладки
log "System info:"
log "  - unblock.py exists: $([ -f /opt/bin/unblock.py ] && echo 'yes' || echo 'no')"
log "  - unblock.py executable: $([ -x /opt/bin/unblock.py ] && echo 'yes' || echo 'no')"
log "  - unblock_dnsmasq.sh exists: $([ -f /opt/bin/unblock_dnsmasq.sh ] && echo 'yes' || echo 'no')"
log "  - unblock_ipset.sh exists: $([ -f /opt/bin/unblock_ipset.sh ] && echo 'yes' || echo 'no')"

case "$1" in
  start)
    log "========================================"
    log "===== S99UNBLOCK START INITIATED ====="
    log "========================================"

    # Step 0: Попробовать Python UnblockManager (новый подход)
    log "Step 0: Checking for Python unblock.py..."
    PYTHON_OK=false
    if [ -x "/opt/bin/unblock.py" ]; then
        log "Found /opt/bin/unblock.py - executing..."
        if /opt/bin/unblock.py update >> "$LOGFILE" 2>&1; then
            log ">>> Python unblock.py SUCCEEDED (exit code: $?)"
            PYTHON_OK=true
            
            # Логируем результат
            log "IPSet status after Python:"
            for setname in unblocksh unblockvless unblocktroj; do
                count=$(ipset list "$setname" 2>/dev/null | grep -c "^[0-9]" || echo 0)
                log "  - $setname: $count entries"
            done
        else
            log_error ">>> Python unblock.py FAILED (exit code: $?)"
            PYTHON_OK=false
            log "Falling back to shell scripts..."
        fi
    else
        log "Python unblock.py NOT FOUND or NOT EXECUTABLE"
        log "Will use shell scripts instead"
    fi

    # Step 1: Ensure dnsmasq is running (needed for DNS resolution in ipset script)
    log "========================================"
    log "Step 1: Ensuring dnsmasq is running..."
    log "========================================"
    if /opt/etc/init.d/S56dnsmasq restart >> "$LOGFILE" 2>&1; then
        log "  dnsmasq restarted successfully"
    else
        log_error "  dnsmasq restart failed, proceeding anyway"
    fi
    sleep 2

    # Step 2: Populate ipsets (только если Python не сработал)
    log "========================================"
    log "Step 2: Populating ipsets..."
    log "========================================"
    if [ "$PYTHON_OK" = "false" ]; then
        log "Python failed, using shell unblock_ipset.sh..."
        if /opt/bin/unblock_ipset.sh >> "$LOGFILE" 2>&1; then
            log "  unblock_ipset.sh completed successfully"
            IPSET_OK=true
        else
            log_error "  unblock_ipset.sh failed (exit code: $?)"
            IPSET_OK=false
        fi
    else
        # Python уже сделал update_all() который включает ipset
        IPSET_OK=true
        log "  IPSet populated by Python (skipping shell)"
    fi

    # Step 3: Verify ipsets have entries before applying redirect rules
    log "========================================"
    log "Step 3: Verifying ipset entries..."
    log "========================================"
    if [ "$IPSET_OK" = "true" ]; then
        TOTAL_ENTRIES=0
        for setname in unblocksh unblockvless unblocktroj; do
            if ipset list "$setname" -n >/dev/null 2>&1; then
                count=$(ipset list "$setname" 2>/dev/null | grep -c "^[0-9]")
                count=${count:-0}
            else
                count=0
            fi
            TOTAL_ENTRIES=$((TOTAL_ENTRIES + count))
            log "  $setname: $count entries"
        done

        if [ "$TOTAL_ENTRIES" -lt 1 ]; then
            log_error "No ipset entries found — SKIPPING redirect rules"
            IPSET_OK=false
        else
            log "Total ipset entries: $TOTAL_ENTRIES"
        fi
    else
        log "IPSet not ready, skipping verification"
    fi

    # Step 4: Apply iptables redirect rules ONLY if ipsets are populated
    log "========================================"
    log "Step 4: Applying iptables redirect rules..."
    log "========================================"
    if [ "$IPSET_OK" = "true" ]; then
        # Try Python first (new approach)
        if [ -x "/opt/bin/unblock.py" ]; then
            log "Trying Python unblock.py for redirects..."
            if /opt/bin/unblock.py apply-redirects >> "$LOGFILE" 2>&1; then
                log "  Python apply-redirects succeeded"
            else
                log "  Python apply-redirects failed, falling back to shell"
                if /opt/etc/ndm/netfilter.d/100-redirect.sh >> "$LOGFILE" 2>&1; then
                    log "  100-redirect.sh completed successfully"
                else
                    log_error "  100-redirect.sh failed (exit code: $?)"
                fi
            fi
        else
            if /opt/etc/ndm/netfilter.d/100-redirect.sh >> "$LOGFILE" 2>&1; then
                log "  100-redirect.sh completed successfully"
            else
                log_error "  100-redirect.sh failed (exit code: $?)"
            fi
        fi
    else
        log_error "SKIPPING 100-redirect.sh — ipsets not ready"
    fi

    # Step 5: Start dnsmasq watchdog (monitors dnsmasq:5353, removes DNAT on crash)
    log "========================================"
    log "Step 5: Starting dnsmasq watchdog..."
    log "========================================"
    # Also update watchdog script to latest version from GitHub
    curl -s -o /opt/bin/dnsmasq_watchdog.sh https://raw.githubusercontent.com/royfincher25-source/flymybyte/master/src/web_ui/resources/scripts/dnsmasq_watchdog.sh 2>/dev/null
    chmod +x /opt/bin/dnsmasq_watchdog.sh 2>/dev/null
    
    if [ -x "/opt/bin/dnsmasq_watchdog.sh" ]; then
        # Kill existing watchdogs - check by /proc to avoid BusyBox ps issues
        killed=0
        for pid in /proc/[0-9]*; do
            pid_num=$(basename "$pid" 2>/dev/null)
            if [ -f "$pid/cmdline" ] && grep -q "dnsmasq_watchdog" "$pid/cmdline" 2>/dev/null; then
                kill -9 "$pid_num" 2>/dev/null && killed=$((killed+1))
            fi
        done
        log "  Killed $killed old watchdog processes"
        rm -f /tmp/dnsmasq_watchdog.pid  # Clear stale lockfile
        sleep 1
        /opt/bin/dnsmasq_watchdog.sh &
        log "  Started dnsmasq watchdog (PID: $!)"
    else
        log "  dnsmasq_watchdog.sh not found, skipping"
    fi

    # Step 6: Sync VPN interfaces (routes + ipsets)
    log "========================================"
    log "Step 6: Syncing VPN interfaces..."
    log "========================================"
    if [ -x "/opt/bin/unblock.py" ]; then
        if /opt/bin/unblock.py sync-vpn >> "$LOGFILE" 2>&1; then
            log "  VPN sync completed"
        else
            log "  VPN sync failed, trying shell 100-unblock-vpn.sh..."
            /opt/etc/ndm/netfilter.d/100-unblock-vpn.sh >> "$LOGFILE" 2>&1 || log "  VPN shell script not found or failed"
        fi
    else
        log "  Python unblock.py not available, skipping VPN sync"
    fi
    
    log "========================================"
    log "===== S99UNBLOCK START COMPLETE ====="
    log "========================================"
    ;;
  stop)
    log "Stopping unblock ipset..."
    log "  Stopping dnsmasq watchdog..."
    for pid in /proc/[0-9]*; do
        if [ -f "$pid/cmdline" ] && grep -q "dnsmasq_watchdog" "$pid/cmdline" 2>/dev/null; then
            pid_num=$(basename "$pid")
            kill -9 "$pid_num" 2>/dev/null && log "  Killed $pid_num" || true
        fi
    done
    log "  Flushing iptables redirect rules..."
    for proto in tcp udp; do
        iptables -t nat -F PREROUTING 2>/dev/null && log "  Flushed PREROUTING ($proto)" || log_error "  Failed to flush PREROUTING ($proto)"
    done
    log "  Clearing ipsets..."
    for setname in unblocksh unblockvless unblocktroj; do
        ipset flush "$setname" 2>/dev/null && log "  Flushed $setname" || log "  $setname not found"
    done
    ;;
  restart)
    log "Restarting unblock..."
    # Kill all watchdogs first
    for pid in /proc/[0-9]*; do
        if [ -f "$pid/cmdline" ] && grep -q "dnsmasq_watchdog" "$pid/cmdline" 2>/dev/null; then
            pid_num=$(basename "$pid")
            kill -9 "$pid_num" 2>/dev/null
        fi
    done
    rm -f /tmp/dnsmasq_watchdog.pid
    sleep 1
    $0 start
    ;;
  *)
    log_error "Unknown action: $1"
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac

log "=== S99unblock finished ==="
exit 0
