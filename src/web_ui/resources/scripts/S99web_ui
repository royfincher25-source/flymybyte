#!/bin/sh
# S99web_ui - Скрипт автозапуска веб-интерфейса

WEB_DIR="/opt/etc/web_ui"
PIDFILE="/var/run/web_ui.pid"

start() {
    echo "Starting web UI..."
    cd "$WEB_DIR"
    python3 app.py > /opt/var/log/web_ui.log 2>&1 &
    echo $! > "$PIDFILE"
    echo "Web UI started"
}

stop() {
    echo "Stopping web UI..."
    if [ -f "$PIDFILE" ]; then
        kill $(cat "$PIDFILE") 2>/dev/null || true
        rm -f "$PIDFILE"
    else
        killall python3 2>/dev/null || true
    fi
    echo "Web UI stopped"
}

restart() {
    stop
    sleep 2
    start
}

status() {
    if pgrep -f "python.*app.py" > /dev/null 2>&1 || pgrep -f "python3.*app.py" > /dev/null 2>&1; then
        echo "Web UI is running"
        exit 0
    else
        echo "Web UI is not running"
        exit 1
    fi
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        restart
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit 0
