#!/bin/sh
# S99web_ui - Скрипт автозапуска веб-интерфейса

WEB_DIR="/opt/etc/web_ui"
PIDFILE="/var/run/web_ui.pid"

start() {
    # FIX: Singleton protection — check if already running
    if [ -f "$PIDFILE" ]; then
        OLD_PID=$(cat "$PIDFILE")
        if kill -0 "$OLD_PID" 2>/dev/null; then
            # Check if port 8080 is actually in use
            if netstat -tlnp 2>/dev/null | grep -q ":8080 "; then
                echo "Web UI already running (PID $OLD_PID)"
                return 0
            fi
        fi
        rm -f "$PIDFILE"
    fi
    
    # Also check for any python3 app.py processes
    if pgrep -f "python.*app.py" > /dev/null 2>&1; then
        echo "Web UI already running (process detected)"
        return 0
    fi
    
    echo "Starting web UI..."
    cd "$WEB_DIR"
    python3 app.py > /opt/var/log/web_ui.log 2>&1 &
    echo $! > "$PIDFILE"
    echo "Web UI started"
}

stop() {
    echo "Stopping web UI..."
    if [ -f "$PIDFILE" ]; then
        kill $(cat "$PIDFILE") 2>/dev/null || true
        rm -f "$PIDFILE"
    fi
    # Also kill any remaining python3 app.py processes
    killall -9 python3 2>/dev/null || true
    # Wait for port 8080 to be released
    i=0
    while [ $i -lt 10 ]; do
        if ! netstat -tlnp 2>/dev/null | grep -q ":8080 "; then
            break
        fi
        sleep 1
        i=$((i + 1))
    done
    echo "Web UI stopped"
}

restart() {
    stop
    start
}

status() {
    if pgrep -f "python.*app.py" > /dev/null 2>&1 || pgrep -f "python3.*app.py" > /dev/null 2>&1; then
        echo "Web UI is running"
        exit 0
    else
        echo "Web UI is not running"
        exit 1
    fi
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        restart
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit 0
